# ============================================================
# PenPath Environment Variables — Master Template
# ============================================================
# Copy this file and fill in real values for your environment.
# Never commit a file that contains real secrets.
#
# Go (Fiber) backend reads these at startup to generate config/config.json.
# Node.js scripts read these via dotenv from .env.local / .env.staging / .env.production.
#
# Where to find Supabase values:
#   Supabase Dashboard > Your Project > Settings > API
# ============================================================


# ------------------------------------------------------------
# Supabase — shared between Go backend and Node.js scripts
# ------------------------------------------------------------

# Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous (public) key — safe to use in frontend and read-only operations
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — admin access, bypasses RLS, never expose to frontend
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Storage bucket name created in Supabase Storage
SUPABASE_STORAGE_BUCKET=penpath-handwriting


# ------------------------------------------------------------
# JWT / Auth — Go (Fiber) backend only
# Used to verify Supabase-issued JWTs on protected routes
# ------------------------------------------------------------

# Issuer matches your Supabase project auth URL
# Format: https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1

# JWKS endpoint Fiber fetches public keys from to verify JWT signatures
# Format: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json


# ------------------------------------------------------------
# Database — Go (Fiber) backend only
# Connection details for Supabase Postgres (direct connection)
# Found in: Supabase Dashboard > Settings > Database > Connection string
# ------------------------------------------------------------

DB_PASSWORD=your_database_password_here


# ------------------------------------------------------------
# Node.js scripts only
# Controls which .env file is loaded and which schema is used
# ------------------------------------------------------------

# Options: local, staging, production
NODE_ENV=local

# Schema name in Supabase
# Options: public_local, public_staging, public_production
DB_SCHEMA=public_local

# Logging verbosity for Node.js scripts
# Options: debug, info, warn, error
LOG_LEVEL=debug
