# ============================================================
# PenPath Backend Environment Variables — Template
# ============================================================
# This file covers both the Go (Fiber) backend and the Node.js scripts.
# Copy to .env.local for local development.
# Never commit a file containing real values.
#
# Supabase values: Dashboard > Your Project > Settings > API
# ============================================================


# ------------------------------------------------------------
# Supabase — used by both Go backend and Node.js scripts
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=penpath-handwriting


# ------------------------------------------------------------
# JWT / Auth — Go (Fiber) backend only
# ------------------------------------------------------------
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json


# ------------------------------------------------------------
# Database — Go (Fiber) backend only
# ------------------------------------------------------------
DB_PASSWORD=your_database_password_here


# ------------------------------------------------------------
# Node.js scripts only
# ------------------------------------------------------------
NODE_ENV=local
DB_SCHEMA=public_local
LOG_LEVEL=debug
