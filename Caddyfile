# Caddyfile — PenPath domain routing config
#
# Caddy is the doorman of the apartment building.
# It reads the domain on every incoming request and forwards it
# to the correct Fiber process running on this server.
#
# Caddy handles automatically for every domain block below:
#   - TLS certificate from Let's Encrypt (free, auto-renewed)
#   - HTTP -> HTTPS redirect
#   - Forwarding (reverse proxy) to the correct Fiber port
#
# Local development does NOT use this file.
# Run Fiber directly with `go run ./cmd/server` for local dev.

# -----------------------------------------------------------------------
# PRODUCTION
# Public API — used by the live mobile app
# DNS: api.penpath.app  ->  your server IP (A record)
# -----------------------------------------------------------------------
api.penpath.app {
    reverse_proxy localhost:3000
}

# -----------------------------------------------------------------------
# STAGING
# Internal testing API — used before releasing to production
# DNS: staging.penpath.app  ->  your server IP (A record)
# -----------------------------------------------------------------------
staging.penpath.app {
    reverse_proxy localhost:3001
}

# -----------------------------------------------------------------------
# LOCAL DEVELOPMENT
# Uncomment this block only when testing Caddy locally.
# Run `caddy trust` once so your browser accepts the local certificate.
# Leave commented out on the production server.
# -----------------------------------------------------------------------
# localhost {
#     reverse_proxy localhost:3000
# }
